<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="755.0" prefWidth="891.0" spacing="20.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.lpnuurvipzlabs.Lab1Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Pane prefHeight="715.0" prefWidth="849.0">
      <children>
          <Button layoutX="65.0" layoutY="358.0" onAction="#onCalculateButtonClick" prefHeight="26.0" prefWidth="77.0" text="Calculate" />
         <TextArea fx:id="resultArea" layoutX="244.0" prefHeight="715.0" prefWidth="608.0" />
         <ImageView fitHeight="163.0" fitWidth="310.0" layoutX="11.0" layoutY="1.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@Lab1-Variant1.jpg" />
            </image>
         </ImageView>
         <Label fx:id="infoLabel" layoutX="41.0" layoutY="189.0" prefHeight="17.0" prefWidth="125.0" text="Label" />
         <RadioButton fx:id="radioButton1" layoutX="47.0" layoutY="240.0" mnemonicParsing="false" prefHeight="17.0" prefWidth="77.0" text="Costs" />
         <RadioButton fx:id="radioButton2" layoutX="47.0" layoutY="286.0" mnemonicParsing="false" prefHeight="17.0" prefWidth="142.0" text="Quantity of Variants" />
      </children>
   </Pane>
</VBox>
